{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "TerraformS3Access",
            "Effect": "Allow",
            "Action": ["s3:*"],
            "Resource": "*"
        },
        {
            "Sid": "TerraformIAMAccess",
            "Effect": "Allow",
            "Action": [
                "iam:CreateUser",
                "iam:DeleteUser",
                "iam:GetUser",
                "iam:ListUsers",

                "iam:CreatePolicy",
                "iam:DeletePolicy",
                "iam:GetPolicy",
                "iam:ListPolicies",
                "iam:GetPolicyVersion",
                "iam:ListPolicyVersions",

                "iam:AttachUserPolicy",
                "iam:DetachUserPolicy",
                "iam:ListAttachedUserPolicies",

                "iam:PutUserPolicy",
                "iam:GetUserPolicy",
                "iam:DeleteUserPolicy",
                "iam:ListUserPolicies"
            ],
            "Resource": "*"
        },  
        {
            "Sid": "TerraformLoggingAccess",
            "Effect": "Allow",
            "Action": ["cloudtrail:*"],
            "Resource": "*"
        }
    ]
}